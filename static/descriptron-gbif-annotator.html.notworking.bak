// STATE
// ═══════════════════════════════════════════════════════════════════════
const $=id=>document.getElementById(id);
let state={imageUrl:"",tool:"bbox",brushSize:10,templateGroupKey:"Formicidae",viewKey:"head_dorsal",
  regions:[],activeRegion:null,occurrenceData:null,sidePanel:"regions",expandedRegion:null,
  isDrawing:false,startPos:null,imgDims:{w:0,h:0,scale:1,ox:0,oy:0},img:null,imgLoaded:false,zoom:1,panX:0,panY:0,isPanning:false,panStart:null,spaceDown:false,
  annotationURI:"",undoStack:[],redoStack:[]};

// ═══════════════════════════════════════════════════════════════════════
// SAM2.1 ONNX CLIENT
// ═══════════════════════════════════════════════════════════════════════
const SAM2={
  apiBase:'',session:null,ready:false,embedding:null,embedding_id:null,origSize:null,inputSize:null,encoding:false,

  init(){
    this.apiBase=window.location.origin;
    this.checkHealth();
  },

  async checkHealth(){
    setSamStatus('off','Connecting...');
    try{
      const r=await fetch(this.apiBase+'/health',{signal:AbortSignal.timeout(5000)});
      const d=await r.json();
      if(d.status==='ok'&&d.encoder_loaded){
        setSamStatus('ready','Encoder ready');
        if(d.onnx_decoder_available) this.loadDecoder();
        else setSamStatus('ready','Encoder only (no ONNX decoder)');
        return true;
      }
      setSamStatus('off','Encoder not loaded');return false;
    }catch(e){setSamStatus('off','API unreachable');return false}
  },

  async loadDecoder(){
    if (this.session) return;

    setSamStatus('encoding','Loading ONNX decoder...');
    try{
      // Ensure ORT can find its WASM binaries
      ort.env.wasm.wasmPaths = 'https://cdn.jsdelivr.net/npm/onnxruntime-web@1.20.0/dist/';
      // Avoid COOP/COEP + SharedArrayBuffer requirements
      ort.env.wasm.numThreads = 1;

      // NOTE: ORT Web commonly uses "cpu" here (WASM backend)
      this.session = await ort.InferenceSession.create(
        this.apiBase + '/onnx/decoder.onnx',
        { executionProviders: ['cpu'] }
      );

      this.ready = true;
      setSamStatus('ready','Decoder ready — draw prompts & click Segment');
      $('segment-btn').disabled = false;
      showToast('SAM2.1 decoder loaded');
    }catch(e){
      console.error('ONNX load failed:', e);
      this.ready = false;
      this.session = null;
      $('segment-btn').disabled = true;

      const msg = (e && e.message !== undefined) ? e.message : String(e);
      setSamStatus('off','ONNX decoder failed: ' + msg);
      showToast('ONNX decoder failed — check console');
    }
  },

  getProxyUrl(url){return this.apiBase+'/proxy-image?url='+encodeURIComponent(url)},

  async encodeImage(imageUrl){
    if(this.encoding)return;
    this.encoding=true;this.embedding=null;
    setSamStatus('encoding','Encoding image (15-30s)...');
    $('segment-btn').disabled=true;
    try{
      const r=await fetch(this.apiBase+'/encode',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({image_url:imageUrl})});
      if(!r.ok)throw new Error((await r.json().catch(()=>({}))).detail||r.statusText);
      const buf=await r.arrayBuffer();
      this.embedding=this.unpack(buf);
      this.origSize={w:parseInt(r.headers.get('X-Orig-Width'))||state.imgDims.w,h:parseInt(r.headers.get('X-Orig-Height'))||state.imgDims.h};
      this.embedding_id = r.headers.get('X-Embedding-Id') || null;
      const cached=r.headers.get('X-Cached')==='true';
      this.encoding=false;
      if (this.ready) {
        $('segment-btn').disabled = false;
        setSamStatus('ready', cached ? 'Cached — ready to segment' : 'Encoded — ready to segment');
      } else {
        if (this.embedding) {
          $('segment-btn').disabled = false;
          setSamStatus('ready', cached ? 'Cached — click Segment' : 'Encoded — click Segment');
        }
       }

      showToast('Image encoded for SAM2');
    }catch(e){
      this.encoding=false;
      setSamStatus('off','Encode failed: '+e.message);
      console.error(e);
    }
  },

  unpack(buf){
    const v=new DataView(buf);let o=0;
    const magic=String.fromCharCode(v.getUint8(0),v.getUint8(1),v.getUint8(2),v.getUint8(3));
    if(magic!=='SAM2')throw new Error('Invalid format');o=4;
    v.getUint32(o,true);o+=4;const origH=v.getUint32(o,true);o+=4;const origW=v.getUint32(o,true);o+=4;
    const inputH=v.getUint32(o,true);o+=4;const inputW=v.getUint32(o,true);o+=4;
    const nt=v.getUint32(o,true);o+=4;o+=4;
    const tensors={};
    for(let t=0;t<nt;t++){
      const nl=v.getUint32(o,true);o+=4;
      const name=new TextDecoder().decode(new Uint8Array(buf,o,nl));o+=nl;
      const nd=v.getUint32(o,true);o+=4;
      const shape=[];for(let d=0;d<nd;d++){shape.push(v.getUint32(o,true));o+=4}
      const dt=v.getUint32(o,true);o+=4;const dl=v.getUint32(o,true);o+=4;
      const raw = new Uint8Array(buf, o, dl);
      o += dl;

      // Make an aligned, standalone buffer (offset = 0)
      const rawBuf = raw.buffer.slice(raw.byteOffset, raw.byteOffset + raw.byteLength);

      let data;
      if (dt === 1) { // float16 stored as uint16
        if (rawBuf.byteLength % 2 !== 0) throw new Error(`Bad f16 byte length for ${name}: ${rawBuf.byteLength}`);
        const f16 = new Uint16Array(rawBuf);
        data = new Float32Array(f16.length);
        for (let i = 0; i < f16.length; i++) data[i] = f16to32(f16[i]);
      } else { // float32
        if (rawBuf.byteLength % 4 !== 0) throw new Error(`Bad f32 byte length for ${name}: ${rawBuf.byteLength}`);
        data = new Float32Array(rawBuf);
      }

      tensors[name] = { data, shape };
    }
    this.inputSize={w:inputW,h:inputH};
    return tensors;
  },

  async predict(prompts){
    if(!this.session||!this.embedding)return null;
    const e=this.embedding;
    const coords=new Float32Array(32);const labels=new Float32Array(16).fill(-1);
    let idx=0;
    const sx=this.inputSize.w/this.origSize.w,sy=this.inputSize.h/this.origSize.h;
    if(prompts.points)prompts.points.forEach(p=>{if(idx<16){coords[idx*2]=p.x*sx;coords[idx*2+1]=p.y*sy;labels[idx]=p.positive!==false?1:0;idx++}});
    if(prompts.bboxes)prompts.bboxes.forEach(b=>{if(idx<15){coords[idx*2]=b.x*sx;coords[idx*2+1]=b.y*sy;labels[idx]=2;idx++;coords[idx*2]=(b.x+b.w)*sx;coords[idx*2+1]=(b.y+b.h)*sy;labels[idx]=3;idx++}});
    if(idx===0)return null;
    const t0=performance.now();
    const feeds={
      image_embed:new ort.Tensor('float32',e.image_embed.data,e.image_embed.shape),
      high_res_feats_0:new ort.Tensor('float32',e.high_res_feats_0.data,e.high_res_feats_0.shape),
      high_res_feats_1:new ort.Tensor('float32',e.high_res_feats_1.data,e.high_res_feats_1.shape),
      point_coords:new ort.Tensor('float32',coords,[1,16,2]),
      point_labels:new ort.Tensor('float32',labels,[1,16]),
      mask_input:new ort.Tensor('float32',new Float32Array(65536),[1,1,256,256]),
      has_mask_input:new ort.Tensor('float32',new Float32Array([0]),[1]),
    };
    const res=await this.session.run(feeds);
    const ms=performance.now()-t0;
    const masks=res.masks,scores=res.iou_predictions;
    const best={idx:0,score:scores.data[0]};
    for(let i=1;i<3;i++)if(scores.data[i]>best.score){best.idx=i;best.score=scores.data[i]}
    const mdata=masks.data.slice(best.idx*65536,(best.idx+1)*65536);
    const binary=new Uint8Array(65536);for(let i=0;i<65536;i++)binary[i]=mdata[i]>0?1:0;
    console.log(`SAM2 predict: ${ms.toFixed(0)}ms, score=${best.score.toFixed(3)}`);
    return{maskData:binary,maskW:256,maskH:256,score:best.score};
  },
};

function f16to32(h){const s=(h>>15)&1,e=(h>>10)&0x1f,m=h&0x3ff;if(e===0)return m===0?(s?-0:0):(s?-1:1)*Math.pow(2,-14)*(m/1024);if(e===31)return m?NaN:(s?-Infinity:Infinity);return(s?-1:1)*Math.pow(2,e-15)*(1+m/1024)}
function setSamStatus(cls,text){$('sam-dot').className='sam-dot '+cls;$('sam-status-text').textContent=text}
function showToast(msg){const t=$('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2500)}

// ═══════════════════════════════════════════════════════════════════════
// ANNOTATION URI
// ═══════════════════════════════════════════════════════════════════════
function generateURI(){state.annotationURI='urn:descriptron:annotation:'+Date.now().toString(36)+'-'+Math.random().toString(36).substring(2,8);$('status-uri').textContent=state.annotationURI}
generateURI();

// ═══════════════════════════════════════════════════════════════════════
// ANNOTATOR LOGIN (optional)
// ═══════════════════════════════════════════════════════════════════════
let annotator = {name:'',orcid:'',institution:''};
function loadAnnotator(){
  try{const s=localStorage.getItem('descriptron_annotator');if(s){annotator=JSON.parse(s);updateLoginUI()}}catch(e){}
}
function saveAnnotator(){
  try{localStorage.setItem('descriptron_annotator',JSON.stringify(annotator))}catch(e){}
  updateLoginUI();
}
function updateLoginUI(){
  const btn=$('login-btn');
  if(annotator.name){
    $('login-label').textContent=annotator.name;
    btn.classList.add('logged-in');
    $('login-icon').textContent='✅';
  } else {
    $('login-label').textContent='Login';
    btn.classList.remove('logged-in');
    $('login-icon').textContent='👤';
  }
}
function getAnnotatorInfo(){
  const info={};
  if(annotator.name)info.annotator_name=annotator.name;
  if(annotator.orcid)info.annotator_orcid=annotator.orcid;
  if(annotator.institution)info.annotator_institution=annotator.institution;
  return Object.keys(info).length?info:null;
}

// ═══════════════════════════════════════════════════════════════════════
// LOCAL IMAGE LOADING (file upload + drag-drop)
// ═══════════════════════════════════════════════════════════════════════
function loadLocalImage(file){
  if(!file||!file.type.startsWith('image/'))return;
  state.zoom=1;state.panX=0;state.panY=0;
  state.occurrenceData=state.occurrenceData||{};
  $('url-input').value=file.name;
  $('canvas-placeholder').style.display='flex';
  $('canvas-placeholder').innerHTML='<div><div class="ph-icon">⏳</div><div>Loading image...</div></div>';

  // Step 1: Read file for immediate canvas display
  const reader=new FileReader();
  reader.onload=function(ev){
    const dataUrl=ev.target.result;
    const img=new Image();
    img.onload=function(){
      state.img=img;state.imgLoaded=true;
      state.imageUrl=file.name;
      state.occurrenceData.imageURL=file.name;
      drawImage();
      showToast('Loaded: '+file.name);

      // Step 2: Upload to server for SAM2 encoding
      uploadImageToServer(file);
    };
    img.onerror=function(){
      $('canvas-placeholder').innerHTML='<div><div class="ph-icon">⚠️</div><div>Failed to load image</div></div>';
    };
    img.src=dataUrl;
  };
  reader.readAsDataURL(file);
}

async function uploadImageToServer(file){
  if(!SAM2.apiBase){setSamStatus('off','No server');return}
  setSamStatus('encoding','Uploading image to server...');
  try{
    const form=new FormData();
    form.append('file',file);
    const r=await fetch(SAM2.apiBase+'/upload-image',{method:'POST',body:form});
    if(!r.ok){
      const err=await r.text().catch(()=>'Upload failed');
      throw new Error(err);
    }
    const data=await r.json();

    // Option 1: FastAPI returns image_url like "/uploads/<name>" OR absolute "http..."
    let serverUrl = data.image_url || data.url;

    // Option 2 fallback: sometimes you might only get a filename
    // (or a relative path without leading slash). Convert to "/uploads/<name>".
    if(!serverUrl && data.filename){
      serverUrl = '/uploads/' + data.filename;
    }
    if(!serverUrl) throw new Error('No URL returned');

    // Normalize relative paths into absolute URLs so /encode can fetch them via httpx
    if(serverUrl.startsWith('/')){
      serverUrl = SAM2.apiBase + serverUrl;
    }else if(!serverUrl.startsWith('http')){
      // relative but missing leading slash (e.g. "uploads/x.jpg" or "x.jpg")
      const cleaned = serverUrl.startsWith('uploads/') ? ('/' + serverUrl) : ('/uploads/' + serverUrl);
      serverUrl = SAM2.apiBase + cleaned;
    }

    // Update state with server-accessible URL
    state.imageUrl = serverUrl;
    state.occurrenceData.imageURL = serverUrl;
    showToast('Uploaded — encoding for SAM2...');

    // Encode using the server URL (same path as GBIF/URL-based images)
    await SAM2.encodeImage(serverUrl);
  }catch(e){
    console.error('Upload failed:',e);
    setSamStatus('off','Upload failed: '+e.message+' — manual annotation only');
    $('segment-btn').disabled=true;
  }
}

// ═══════════════════════════════════════════════════════════════════════
// UNDO/REDO
// ═══════════════════════════════════════════════════════════════════════
function saveUndo(){state.undoStack.push(JSON.parse(JSON.stringify(state.regions.map(r=>({id:r.id,annotations:r.annotations,attributes:r.attributes,notes:r.notes,sam2_mask:r.sam2_mask})))));if(state.undoStack.length>50)state.undoStack.shift();state.redoStack=[]}
function undo(){if(!state.undoStack.length)return;state.redoStack.push(JSON.parse(JSON.stringify(state.regions.map(r=>({id:r.id,annotations:r.annotations,attributes:r.attributes,notes:r.notes,sam2_mask:r.sam2_mask})))));const p=state.undoStack.pop();p.forEach(s=>{const r=state.regions.find(r=>r.id===s.id);if(r){r.annotations=s.annotations;r.attributes=s.attributes;r.notes=s.notes;r.sam2_mask=s.sam2_mask}});renderOverlay();renderRegions();updateStatus()}
function redo(){if(!state.redoStack.length)return;state.undoStack.push(JSON.parse(JSON.stringify(state.regions.map(r=>({id:r.id,annotations:r.annotations,attributes:r.attributes,notes:r.notes,sam2_mask:r.sam2_mask})))));const n=state.redoStack.pop();n.forEach(s=>{const r=state.regions.find(r=>r.id===s.id);if(r){r.annotations=s.annotations;r.attributes=s.attributes;r.notes=s.notes;r.sam2_mask=s.sam2_mask}});renderOverlay();renderRegions();updateStatus()}

// ═══════════════════════════════════════════════════════════════════════
// TEMPLATE SYSTEM
// ═══════════════════════════════════════════════════════════════════════
function autoDetect(occ){for(const k of[occ.family,occ.order,occ.class,"Insecta","Arthropoda"]){if(k&&TAXON_TEMPLATES[k]){const g=TAXON_TEMPLATES[k],fk=Object.keys(g)[0];for(const[ak,av]of Object.entries(ALL_TEMPLATES)){if(av===g[fk]){const p=ak.split("__");state.templateGroupKey=p[0];state.viewKey=p[1];loadTemplate();$('auto-detect-msg').style.display='block';$('auto-detect-msg').innerHTML=`Detected: <strong>${k}</strong> <span class="auto-badge">AUTO</span>`;return k}}}}return null}
function loadTemplate(){const k=`${state.templateGroupKey}__${state.viewKey}`,t=ALL_TEMPLATES[k];if(!t)return;state.regions=t.regions.map(r=>({...r,annotations:[],attributes:{},notes:"",templateAttributes:t.attributes,sam2_mask:null}));state.activeRegion=t.regions[0]?.id||null;state.expandedRegion=null;state.undoStack=[];state.redoStack=[];renderRegions();renderOverlay();updateStatus();$('template-info').textContent=`${t.regions.length} regions · ${t.group}`;$('status-template').textContent=`${t.group} — ${t.view}`;updateViewSelect()}
function updateViewSelect(){const vs=$('view-select'),pf=state.templateGroupKey+"__";vs.innerHTML=Object.keys(ALL_TEMPLATES).filter(k=>k.startsWith(pf)).map(k=>{const vk=k.replace(pf,""),t=ALL_TEMPLATES[k];return`<option value="${vk}"${vk===state.viewKey?' selected':''}>${t.view}</option>`}).join('')}
function initTemplateSelect(){const s=$('template-select');s.innerHTML=Object.keys(Object.fromEntries(Object.keys(ALL_TEMPLATES).map(k=>[k.split("__")[0],1]))).map(g=>`<option value="${g}"${g===state.templateGroupKey?' selected':''}>${g}</option>`).join('');s.addEventListener('change',()=>{state.templateGroupKey=s.value;const f=Object.keys(ALL_TEMPLATES).find(k=>k.startsWith(s.value+"__"));state.viewKey=f?f.replace(s.value+"__",""):"";$('auto-detect-msg').style.display='none';loadTemplate()});$('view-select').addEventListener('change',()=>{state.viewKey=$('view-select').value;loadTemplate()});updateViewSelect()}

// ═══════════════════════════════════════════════════════════════════════
// TOOLS
// ═══════════════════════════════════════════════════════════════════════
function initTools(){const tools=[{id:"bbox",icon:"▢",label:"Bounding Box",sc:"B"},{id:"point",icon:"◉",label:"Point Prompt",sc:"P"},{id:"brush",icon:"🖌",label:"Paintbrush",sc:"D"},{id:"eraser",icon:"⌫",label:"Eraser",sc:"E"},{id:"keypoint",icon:"📌",label:"Keypoint",sc:"K"},{id:"undo",icon:"↩",label:"Undo",sc:"Z"},{id:"redo",icon:"↪",label:"Redo",sc:"Y"}];$('tools-container').innerHTML=tools.map(t=>`<button class="tool-btn${t.id===state.tool?' active':''}" data-tool="${t.id}"><span class="icon">${t.icon}</span><span>${t.label}</span><span class="shortcut">${t.sc}</span></button>`).join('');$('tools-container').querySelectorAll('.tool-btn').forEach(b=>b.addEventListener('click',()=>{const t=b.dataset.tool;if(t==='undo'){undo();return}if(t==='redo'){redo();return}setTool(t)}))}
function setTool(t){state.tool=t;document.querySelectorAll('.tool-btn').forEach(b=>{if(!['undo','redo'].includes(b.dataset.tool))b.classList.toggle('active',b.dataset.tool===t)});$('brush-controls').style.display=(t==='brush'||t==='eraser')?'block':'none';$('overlay-canvas').style.cursor={bbox:"crosshair",point:"crosshair",brush:"cell",eraser:"cell",keypoint:"crosshair"}[t]||"default";$('status-tool').textContent=t}

// ═══════════════════════════════════════════════════════════════════════
// GBIF SEARCH
// ═══════════════════════════════════════════════════════════════════════
async function searchGBIF(){const q=$('search-input').value.trim(),m=$('search-mode').value;if(!q)return;$('search-btn').disabled=true;$('search-btn').textContent='...';try{let res=[];if(m==='occurrence'){const r=await fetch(`https://api.gbif.org/v1/occurrence/${q}`);const d=await r.json();if(d.media?.length)res=[d]}else{const sr=await fetch(`https://api.gbif.org/v1/species/match?name=${encodeURIComponent(q)}`);const sd=await sr.json();if(sd.usageKey){const r=await fetch(`https://api.gbif.org/v1/occurrence/search?taxonKey=${sd.usageKey}&mediaType=StillImage&limit=20`);res=(await r.json()).results||[]}}renderResults(res)}catch(e){console.error(e);renderResults([])}finally{$('search-btn').disabled=false;$('search-btn').textContent='Search GBIF'}}
function renderResults(res){const c=$('results-container');if(!res.length){c.innerHTML='';return}c.innerHTML=`<div class="results-list">${res.map((o,i)=>{const img=o.media?.find(m=>m.type==='StillImage')||o.media?.[0];return`<div class="result-item" data-idx="${i}">${img?.identifier?`<img src="${img.identifier}" class="result-thumb" crossorigin="anonymous" onerror="this.style.display='none'">`:'<div class="result-thumb"></div>'}<div style="flex:1;min-width:0"><div class="result-name">${o.scientificName||o.species||'Unknown'}</div><div class="result-meta">${o.institutionCode||''} · ${o.order||''} · ID:${o.key||o.gbifID}</div></div></div>`}).join('')}</div>`;c.querySelectorAll('.result-item').forEach(el=>el.addEventListener('click',()=>{selectOcc(res[parseInt(el.dataset.idx)]);c.innerHTML=''}))}
function selectOcc(occ){const media=occ.media?.find(m=>m.type==='StillImage')||occ.media?.[0];if(!media?.identifier)return;state.occurrenceData={occurrenceID:occ.key||occ.gbifID,scientificName:occ.scientificName||'',species:occ.species||'',family:occ.family||'',order:occ.order||'',class:occ.class||'',phylum:occ.phylum||'',institutionCode:occ.institutionCode||'',catalogNumber:occ.catalogNumber||'',locality:occ.locality||'',country:occ.country||'',decimalLatitude:occ.decimalLatitude,decimalLongitude:occ.decimalLongitude,imageURL:media.identifier};$('specimen-info').style.display='block';$('specimen-name').textContent=state.occurrenceData.scientificName;$('specimen-meta').textContent=`GBIF:${state.occurrenceData.occurrenceID} · ${state.occurrenceData.family||''} (${state.occurrenceData.order||''})`;autoDetect(state.occurrenceData);generateURI();loadImage(media.identifier)}

// ═══════════════════════════════════════════════════════════════════════
// IMAGE LOADING (via proxy)
// ═══════════════════════════════════════════════════════════════════════
function loadImage(url){state.imageUrl=url;state.imgLoaded=false;state.zoom=1;state.panX=0;state.panY=0;$('url-input').value=url;$('canvas-placeholder').style.display='flex';$('canvas-placeholder').innerHTML='<div><div class="ph-icon">⏳</div><div>Loading...</div></div>';const proxyUrl=SAM2.apiBase?SAM2.getProxyUrl(url):url;const img=new Image();img.crossOrigin='anonymous';img.onload=()=>{state.img=img;state.imgLoaded=true;drawImage();SAM2.encodeImage(url)};img.onerror=()=>{const img2=new Image();img2.onload=()=>{state.img=img2;state.imgLoaded=true;drawImage();SAM2.encodeImage(url)};img2.onerror=()=>{$('canvas-placeholder').innerHTML='<div><div class="ph-icon">⚠️</div><div>Failed to load image</div></div>'};img2.src=url};img.src=proxyUrl}
function drawImage(){if(!state.imgLoaded||!state.img)return;$('canvas-placeholder').style.display='none';const ct=$('canvas-container'),cw=ct.clientWidth,ch=ct.clientHeight;const ic=$('img-canvas'),oc=$('overlay-canvas');ic.width=cw;ic.height=ch;oc.width=cw;oc.height=ch;
  const img=state.img,baseScale=Math.min(cw/img.width,ch/img.height);
  const scale=baseScale*state.zoom;
  const ox=(cw-img.width*scale)/2+state.panX;
  const oy=(ch-img.height*scale)/2+state.panY;
  state.imgDims={w:img.width,h:img.height,scale,ox,oy};
  const ctx=ic.getContext('2d');ctx.clearRect(0,0,cw,ch);ctx.fillStyle='#e8e8e8';ctx.fillRect(0,0,cw,ch);ctx.drawImage(img,ox,oy,img.width*scale,img.height*scale);renderOverlay();updateZoomStatus()}

// ═══════════════════════════════════════════════════════════════════════
// OVERLAY RENDERING (annotations + SAM2 masks)
// ═══════════════════════════════════════════════════════════════════════
function renderOverlay(){const o=$('overlay-canvas');if(!o.width)return;const ctx=o.getContext('2d');ctx.clearRect(0,0,o.width,o.height);const d=state.imgDims;
state.regions.forEach(r=>{const col=r.color||'#fff';
  // SAM2 mask
  if(r.sam2_mask){
    const m=r.sam2_mask,tmp=document.createElement('canvas');tmp.width=m.maskW;tmp.height=m.maskH;const tc=tmp.getContext('2d');const id=tc.createImageData(m.maskW,m.maskH);
    const rgb=hexToRgb(col);for(let i=0;i<m.maskData.length;i++){const px=i*4;if(m.maskData[i]){id.data[px]=rgb.r;id.data[px+1]=rgb.g;id.data[px+2]=rgb.b;id.data[px+3]=90}}
    tc.putImageData(id,0,0);ctx.drawImage(tmp,d.ox,d.oy,d.w*d.scale,d.h*d.scale);
  }
  if(!r.annotations)return;
  r.annotations.filter(a=>a.type==='bbox').forEach(a=>{const x=a.x*d.scale+d.ox,y=a.y*d.scale+d.oy,w=a.w*d.scale,h=a.h*d.scale;ctx.strokeStyle=col;ctx.lineWidth=2;ctx.setLineDash([6,3]);ctx.strokeRect(x,y,w,h);ctx.setLineDash([]);ctx.fillStyle=col+'15';ctx.fillRect(x,y,w,h);ctx.fillStyle=col;ctx.font='bold 11px Roboto';ctx.fillText(r.label,x+3,y-4)});
  r.annotations.filter(a=>a.type==='point').forEach(a=>{const x=a.x*d.scale+d.ox,y=a.y*d.scale+d.oy;ctx.beginPath();ctx.arc(x,y,6,0,Math.PI*2);ctx.fillStyle=a.positive?'#43a047':'#e53935';ctx.fill();ctx.strokeStyle='white';ctx.lineWidth=2;ctx.stroke();ctx.fillStyle='white';ctx.font='bold 10px monospace';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(a.positive?'+':'−',x,y);ctx.textAlign='start';ctx.textBaseline='alphabetic'});
  // Keypoints (numbered landmarks)
  r.annotations.filter(a=>a.type==='keypoint').forEach(a=>{const x=a.x*d.scale+d.ox,y=a.y*d.scale+d.oy;ctx.beginPath();ctx.arc(x,y,9,0,Math.PI*2);ctx.fillStyle=col;ctx.fill();ctx.strokeStyle='white';ctx.lineWidth=2;ctx.stroke();ctx.fillStyle='white';ctx.font='bold 9px Roboto Mono';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(String(a.number),x,y);ctx.textAlign='start';ctx.textBaseline='alphabetic'});
  r.annotations.filter(a=>a.type==='stroke'&&!a.eraser).forEach(a=>{if(a.points.length<2)return;ctx.beginPath();ctx.strokeStyle=col+'80';ctx.lineWidth=(a.brushSize||8)*d.scale;ctx.lineCap='round';ctx.lineJoin='round';ctx.moveTo(a.points[0].x*d.scale+d.ox,a.points[0].y*d.scale+d.oy);for(let i=1;i<a.points.length;i++)ctx.lineTo(a.points[i].x*d.scale+d.ox,a.points[i].y*d.scale+d.oy);ctx.stroke()});
  r.annotations.filter(a=>a.type==='stroke'&&a.eraser).forEach(a=>{if(a.points.length<2)return;ctx.save();ctx.globalCompositeOperation='destination-out';ctx.beginPath();ctx.strokeStyle='rgba(0,0,0,1)';ctx.lineWidth=(a.brushSize||8)*d.scale;ctx.lineCap='round';ctx.lineJoin='round';ctx.moveTo(a.points[0].x*d.scale+d.ox,a.points[0].y*d.scale+d.oy);for(let i=1;i<a.points.length;i++)ctx.lineTo(a.points[i].x*d.scale+d.ox,a.points[i].y*d.scale+d.oy);ctx.stroke();ctx.restore()});
})}
function hexToRgb(hex){const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);return{r,g,b}}
async function postJSON(url, obj){
  const r = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(obj)
  });
  if (!r.ok) throw new Error(await r.text());
  return await r.json();
}

function b64ToU8(b64){
  const bin = atob(b64);
  const out = new Uint8Array(bin.length);
  for (let i = 0; i < bin.length; i++) out[i] = bin.charCodeAt(i);
  return out;
}

// ═══════════════════════════════════════════════════════════════════════
// ZOOM & PAN
// ═══════════════════════════════════════════════════════════════════════
const ZOOM_MIN=0.25,ZOOM_MAX=20,ZOOM_STEP=1.15;
function zoomAt(cx,cy,factor){
  const oldZoom=state.zoom;
  state.zoom=Math.min(ZOOM_MAX,Math.max(ZOOM_MIN,state.zoom*factor));
  const r=state.zoom/oldZoom;
  // Adjust pan so zoom is centered on cursor position
  const ct=$('canvas-container'),cw=ct.clientWidth,ch=ct.clientHeight;
  const centerX=cw/2+state.panX,centerY=ch/2+state.panY;
  state.panX=cx-(cx-state.panX)*r;
  state.panY=cy-(cy-state.panY)*r;
  drawImage();
}
function resetZoom(){state.zoom=1;state.panX=0;state.panY=0;drawImage()}
function updateZoomStatus(){const el=$('status-zoom');if(el)el.textContent=Math.round(state.zoom*100)+'%'}

// ═══════════════════════════════════════════════════════════════════════
// CANVAS EVENTS
// ═══════════════════════════════════════════════════════════════════════
function getCoords(e){const rect=$('overlay-canvas').getBoundingClientRect(),d=state.imgDims;return{ix:(e.clientX-rect.left-d.ox)/d.scale,iy:(e.clientY-rect.top-d.oy)/d.scale}}
function getCanvasPos(e){const rect=$('overlay-canvas').getBoundingClientRect();return{cx:e.clientX-rect.left,cy:e.clientY-rect.top}}
function onMouseDown(e){
  // Pan: middle-click or space+left-click
  if(e.button===1||(state.spaceDown&&e.button===0)){e.preventDefault();state.isPanning=true;state.panStart={x:e.clientX-state.panX,y:e.clientY-state.panY};return}
  if(state.spaceDown)return;
  if(!state.activeRegion||!state.imgLoaded)return;const{ix,iy}=getCoords(e);if(state.tool==='bbox'){saveUndo();state.startPos={x:ix,y:iy};state.isDrawing=true}else if(state.tool==='point'){saveUndo();addAnn(state.activeRegion,{type:'point',x:ix,y:iy,positive:e.button!==2})}else if(state.tool==='keypoint'){saveUndo();const kr=state.regions.find(r=>r.id===state.activeRegion);const kn=kr?kr.annotations.filter(a=>a.type==='keypoint').length:0;addAnn(state.activeRegion,{type:'keypoint',x:ix,y:iy,number:kn+1})}else if(state.tool==='brush'||state.tool==='eraser'){saveUndo();addAnn(state.activeRegion,{type:'stroke',points:[{x:ix,y:iy}],brushSize:state.brushSize,eraser:state.tool==='eraser'});state.isDrawing=true}}
function onMouseMove(e){
  if(state.isPanning&&state.panStart){state.panX=e.clientX-state.panStart.x;state.panY=e.clientY-state.panStart.y;$('overlay-canvas').style.cursor='grabbing';drawImage();return}
  if(!state.isDrawing||!state.activeRegion)return;const{ix,iy}=getCoords(e);if(state.tool==='brush'||state.tool==='eraser'){const r=state.regions.find(r=>r.id===state.activeRegion);if(r?.annotations?.length){const l=r.annotations[r.annotations.length-1];if(l.type==='stroke'){l.points.push({x:ix,y:iy});renderOverlay()}}}}
function onMouseUp(e){
  if(state.isPanning){state.isPanning=false;state.panStart=null;return}
  if(!state.isDrawing||!state.activeRegion)return;if(state.tool==='bbox'&&state.startPos){const{ix,iy}=getCoords(e);const x=Math.min(state.startPos.x,ix),y=Math.min(state.startPos.y,iy),w=Math.abs(ix-state.startPos.x),h=Math.abs(iy-state.startPos.y);if(w>5&&h>5)addAnn(state.activeRegion,{type:'bbox',x,y,w,h})}state.isDrawing=false;state.startPos=null}
function addAnn(rid,ann){const r=state.regions.find(r=>r.id===rid);if(r){r.annotations.push(ann);renderOverlay();renderRegions();updateStatus()}}

// ═══════════════════════════════════════════════════════════════════════
// SAM2 SEGMENT BUTTON
// ═══════════════════════════════════════════════════════════════════════
async function runSegment(){
  if(!SAM2.embedding || !state.activeRegion) return;

  const r = state.regions.find(r => r.id === state.activeRegion);
  if(!r) return;

  const points = r.annotations.filter(a=>a.type==='point').map(a=>({x:a.x,y:a.y,positive:a.positive}));
  const bboxes = r.annotations.filter(a=>a.type==='bbox').map(a=>({x:a.x,y:a.y,w:a.w,h:a.h}));

  if(!points.length && !bboxes.length){
    showToast('Draw points or bbox first');
    return;
  }

  $('segment-btn').disabled = true;
  $('segment-btn').textContent = '⚡ Segmenting...';

  try{
    saveUndo();

    let mask = null;

    if (SAM2.ready) {
      // Browser-side decode (your existing path)
      mask = await SAM2.predict({points,bboxes});
    } else {
      // Server-side decode fallback
      setSamStatus('encoding','Decoding on server...');

      const payload = {
        // You'll need your FastAPI to accept these fields.
        // embedding_id is optional if your server can key by image_url,
        // but embedding_id is best for caching.
        embedding_id: SAM2.embedding_id || null,
        image_url: state.imageUrl,
        points: points.map(p => ({ x: p.x, y: p.y, label: p.positive ? 1 : 0 })),
        bboxes: bboxes
      };

      const out = await postJSON(SAM2.apiBase + '/decode', payload);

      // Expect server to return:
      // { mask_w, mask_h, mask_b64, score }
      mask = {
        maskW: out.mask_w,
        maskH: out.mask_h,
        maskData: b64ToU8(out.mask_b64),
        score: out.score ?? 0.0
      };

      setSamStatus('ready','Mask ready');
    }

    if(mask){
      r.sam2_mask = mask;
      renderOverlay();
      renderRegions();
      showToast(`Segmented: score ${mask.score.toFixed(3)}`);
    } else {
      showToast('No mask predicted');
    }
  }catch(e){
    showToast('Segment failed: ' + e.message);
    console.error(e);
  }finally{
    $('segment-btn').disabled = false;
    $('segment-btn').textContent = '⚡ Segment Region';
  }
}
// ═══════════════════════════════════════════════════════════════════════
// REGIONS PANEL
// ═══════════════════════════════════════════════════════════════════════
function renderRegions(){if(state.sidePanel!=='regions')return;const c=$('panel-content'),k=`${state.templateGroupKey}__${state.viewKey}`,t=ALL_TEMPLATES[k];
c.innerHTML=state.regions.map((r,i)=>{const act=state.activeRegion===r.id,exp=state.expandedRegion===r.id,cnt=(r.annotations?.length||0)+(r.sam2_mask?1:0);
let h=`<div class="region-item${act?' active':''}" data-region="${r.id}"><div class="region-color" style="background:${r.color}"></div><div style="flex:1;min-width:0"><div class="region-label">${i+1}. ${r.label}</div><div class="region-ontology">${r.ontology}</div></div>${cnt>0?`<span class="region-badge">${cnt}</span>`:''}</div>`;
if(exp){h+=`<div class="attr-editor">`;if(t?.attributes)Object.entries(t.attributes).forEach(([an,opts])=>{h+=`<div class="attr-label">${an}</div><select class="attr-select" data-region="${r.id}" data-attr="${an}"><option value="">—</option>${opts.map(o=>`<option value="${o}"${r.attributes?.[an]===o?' selected':''}>${o}</option>`).join('')}</select>`});
h+=`<textarea class="attr-notes" data-region="${r.id}" placeholder="Notes...">${r.notes||''}</textarea>`;if(cnt>0)h+=`<button class="clear-btn" data-clear="${r.id}">Clear All</button>`;h+=`</div>`}return h}).join('');
c.querySelectorAll('.region-item').forEach(el=>el.addEventListener('click',()=>{const rid=el.dataset.region;state.activeRegion=rid;state.expandedRegion=state.expandedRegion===rid?null:rid;renderRegions();updateStatus()}));
c.querySelectorAll('.attr-select').forEach(el=>el.addEventListener('change',()=>{const r=state.regions.find(r=>r.id===el.dataset.region);if(r)r.attributes[el.dataset.attr]=el.value}));
c.querySelectorAll('.attr-notes').forEach(el=>el.addEventListener('input',()=>{const r=state.regions.find(r=>r.id===el.dataset.region);if(r)r.notes=el.value}));
c.querySelectorAll('.clear-btn').forEach(el=>el.addEventListener('click',e=>{e.stopPropagation();saveUndo();const r=state.regions.find(r=>r.id===el.dataset.clear);if(r){r.annotations=[];r.attributes={};r.notes='';r.sam2_mask=null;renderRegions();renderOverlay();updateStatus()}}))}

// ═══════════════════════════════════════════════════════════════════════
// EXPORT
// ═══════════════════════════════════════════════════════════════════════
function renderExport(){if(state.sidePanel!=='export')return;const ann=state.regions.filter(r=>r.annotations?.length>0||r.sam2_mask||(r.attributes&&Object.values(r.attributes).some(v=>v))).length;
const aname=annotator.name?'<div style="color:var(--gbif-green-dark);font-size:11px;margin-bottom:8px">✅ Annotator: <strong>'+annotator.name+'</strong>'+(annotator.institution?' · '+annotator.institution:'')+'</div>':'<div style="color:var(--text-light);font-size:10px;margin-bottom:8px">💡 <a href="#" onclick="document.getElementById(\'login-btn\').click();return false" style="color:var(--gbif-green)">Login</a> to add your name to exports</div>';
$('panel-content').innerHTML=`<div class="panel-label">Export</div>${aname}<div style="color:var(--text-muted);font-size:11px;margin-bottom:8px">${ann}/${state.regions.length} regions annotated</div><div style="color:var(--text-light);font-size:9px;margin-bottom:8px;word-break:break-all">URI: ${state.annotationURI}</div><button class="export-btn primary" id="exp-json">📥 Darwin Core JSON</button><button class="export-btn primary" id="exp-coco">📥 COCO JSON</button><button class="export-btn secondary" id="exp-csv">📊 Traits CSV</button>`;
$('exp-json').addEventListener('click',exportDwC);$('exp-csv').addEventListener('click',exportCSV);$('exp-coco').addEventListener('click',exportCOCO)}
function exportDwC(){const meas=[];state.regions.forEach(r=>{if(r.attributes)Object.entries(r.attributes).forEach(([a,v])=>{if(v)meas.push({measurementType:`${r.label}:${a}`,measurementValue:v,measurementMethod:'Descriptron Web Annotator'})})});const anns={};state.regions.forEach(r=>{if(r.annotations?.length||r.sam2_mask||Object.values(r.attributes||{}).some(v=>v))anns[r.id]={label:r.label,ontology:r.ontology,color:r.color,annotations:r.annotations,sam2_mask:r.sam2_mask?{score:r.sam2_mask.score}:null,attributes:r.attributes||{},notes:r.notes||''}});
const data={meta:{format:'Descriptron-DwC-Annotation',version:'1.1',timestamp:new Date().toISOString(),annotationURI:state.annotationURI,template:`${state.templateGroupKey}/${state.viewKey}`,annotator:getAnnotatorInfo()},occurrence:{occurrenceID:state.occurrenceData?.occurrenceID||'',scientificName:state.occurrenceData?.scientificName||'',family:state.occurrenceData?.family||'',order:state.occurrenceData?.order||'',class:state.occurrenceData?.class||'',institutionCode:state.occurrenceData?.institutionCode||'',imageURL:state.occurrenceData?.imageURL||''},measurements:meas,annotations:anns};
dl(JSON.stringify(data,null,2),'application/json',`descriptron_${(state.occurrenceData?.scientificName||'specimen').replace(/[^a-zA-Z0-9]/g,'_')}_${state.occurrenceData?.occurrenceID||'unknown'}.json`)}
function exportCSV(){const rows=[['annotationURI','occurrenceID','scientificName','region','ontologyID','attribute','value','notes','annotator']];state.regions.forEach(r=>{if(r.attributes)Object.entries(r.attributes).forEach(([a,v])=>{if(v)rows.push([state.annotationURI,state.occurrenceData?.occurrenceID||'',state.occurrenceData?.scientificName||'',r.label,r.ontology,a,v,r.notes||'',annotator.name||''])})});dl(rows.map(r=>r.map(c=>`"${c}"`).join(',')).join('\n'),'text/csv',`descriptron_traits_${state.occurrenceData?.occurrenceID||'unknown'}.csv`)}
function exportCOCO(){
  const images=[{id:1,file_name:state.occurrenceData?.imageURL||state.imageUrl,width:state.imgDims.w,height:state.imgDims.h,gbif_occurrence_id:state.occurrenceData?.occurrenceID||''}];
  const cats=state.regions.map((r,i)=>({id:i+1,name:r.id,label:r.label,ontology:r.ontology}));
  const anns=[];let aid=1;
  state.regions.forEach((r,ri)=>{
    r.annotations?.filter(a=>a.type==='bbox').forEach(a=>{
      anns.push({id:aid++,image_id:1,category_id:ri+1,bbox:[a.x,a.y,a.w,a.h],area:a.w*a.h,iscrowd:0});
    });
    if(r.sam2_mask&&r.sam2_mask.maskData){
      const rle=maskToRLE(r.sam2_mask.maskData,r.sam2_mask.maskW,r.sam2_mask.maskH);
      anns.push({id:aid++,image_id:1,category_id:ri+1,segmentation:{counts:rle.counts,size:rle.size},area:Array.from(r.sam2_mask.maskData).reduce((s,v)=>s+v,0),iscrowd:0,score:r.sam2_mask.score});
    }
    const kpts=(r.annotations||[]).filter(a=>a.type==='keypoint').sort((a,b)=>a.number-b.number);
    if(kpts.length>0){
      const ka=[];const kn=[];
      kpts.forEach(k=>{ka.push(Math.round(k.x),Math.round(k.y),2);kn.push('kpt_'+k.number)});
      anns.push({id:aid++,image_id:1,category_id:ri+1,keypoints:ka,num_keypoints:kpts.length,keypoint_names:kn,iscrowd:0});
    }
  });
  dl(JSON.stringify({info:{description:'Descriptron GBIF Annotation',version:'2.0',annotation_uri:state.annotationURI,annotator:getAnnotatorInfo()},images,categories:cats,annotations:anns},null,2),'application/json',`descriptron_coco_${state.occurrenceData?.occurrenceID||'unknown'}.json`);
}
// ═══════════════════════════════════════════════════════════════════════
// RLE MASK ENCODING/DECODING (COCO-compatible, column-major order)
// ═══════════════════════════════════════════════════════════════════════
function maskToRLE(maskData,w,h){
  const counts=[];let cur=0,cnt=0;
  for(let x=0;x<w;x++){for(let y=0;y<h;y++){
    const v=maskData[y*w+x]?1:0;
    if(v===cur){cnt++}else{counts.push(cnt);cur=v;cnt=1}
  }}
  counts.push(cnt);
  return{counts:counts,size:[h,w]};
}
function rleToMask(rle){
  const h=rle.size[0],w=rle.size[1];
  const mask=new Uint8Array(h*w);
  let idx=0,val=0;
  for(let c=0;c<rle.counts.length;c++){
    const run=rle.counts[c];
    for(let i=0;i<run;i++){
      if(val===1){const x=Math.floor(idx/h),y=idx%h;if(y<h&&x<w)mask[y*w+x]=1}
      idx++;
    }
    val=1-val;
  }
  return{maskData:mask,maskW:w,maskH:h};
}
function dl(content,mime,filename){const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([content],{type:mime}));a.download=filename;a.click();URL.revokeObjectURL(a.href)}

// COCO JSON IMPORT
// ═══════════════════════════════════════════════════════════════════════
function importCOCO(json){
  try{
    const data=JSON.parse(json);
    if(data.annotations&&data.categories){
      if(data.images&&data.images[0]){
        const img=data.images[0];
        if(img.file_name&&img.file_name.startsWith('http')&&!state.imgLoaded){loadImage(img.file_name)}
        if(img.gbif_occurrence_id){
          state.occurrenceData=state.occurrenceData||{};
          state.occurrenceData.occurrenceID=img.gbif_occurrence_id;
          state.occurrenceData.imageURL=img.file_name;
        }
      }
      let imported=0;
      data.categories.forEach(cat=>{
        const r=state.regions.find(r=>r.id===cat.name||r.label===cat.label||r.label===cat.name);
        if(!r)return;
        data.annotations.filter(a=>a.category_id===cat.id).forEach(a=>{
          if(a.bbox&&a.bbox.length===4){r.annotations.push({type:'bbox',x:a.bbox[0],y:a.bbox[1],w:a.bbox[2],h:a.bbox[3]});imported++}
          if(a.segmentation&&a.segmentation.counts&&a.segmentation.size){
            const dec=rleToMask(a.segmentation);
            r.sam2_mask={maskData:dec.maskData,maskW:dec.maskW,maskH:dec.maskH,score:a.score||0};
            imported++;
          }
          if(a.keypoints&&a.keypoints.length>=3){
            for(let i=0;i<a.keypoints.length;i+=3){
              if(a.keypoints[i+2]>0){
                r.annotations.push({type:'keypoint',x:a.keypoints[i],y:a.keypoints[i+1],number:Math.floor(i/3)+1});
                imported++;
              }
            }
          }
        });
      });
      renderOverlay();renderRegions();updateStatus();
      showToast('Imported '+imported+' annotations');
    }
    else if(data.annotations&&data.meta&&data.meta.format&&data.meta.format.indexOf('Descriptron')>=0){
      const keys=Object.keys(data.annotations);
      for(let k=0;k<keys.length;k++){
        const rid=keys[k],ann=data.annotations[rid];
        const r=state.regions.find(function(r){return r.id===rid});
        if(r){if(ann.annotations)r.annotations=ann.annotations;if(ann.attributes)r.attributes=ann.attributes;if(ann.notes)r.notes=ann.notes}
      }
      renderOverlay();renderRegions();updateStatus();
      showToast('Imported Descriptron annotations');
    }
    else showToast('Unrecognized JSON format');
  }catch(e){showToast('Invalid JSON: '+e.message)}
}

// ═══════════════════════════════════════════════════════════════════════
// STATUS
// ═══════════════════════════════════════════════════════════════════════
function updateStatus(){const ar=state.regions.find(r=>r.id===state.activeRegion);$('status-region').textContent=ar?.label||'none';$('status-region').style.color=ar?.color||'var(--text-light)';const ann=state.regions.filter(r=>r.annotations?.length>0||r.sam2_mask).length;$('status-progress').textContent=`${ann}/${state.regions.length}`}
function switchPanel(tab){state.sidePanel=tab;document.querySelectorAll('.panel-tab').forEach(t=>t.classList.toggle('active',t.dataset.tab===tab));if(tab==='regions')renderRegions();else renderExport()}

// ═══════════════════════════════════════════════════════════════════════
// KEYBOARD
// ═══════════════════════════════════════════════════════════════════════
document.addEventListener('keydown',e=>{if(['INPUT','TEXTAREA','SELECT'].includes(e.target.tagName))return;if((e.ctrlKey||e.metaKey)&&e.key==='z'){e.preventDefault();undo();return}if((e.ctrlKey||e.metaKey)&&e.key==='y'){e.preventDefault();redo();return}if(e.key==='s'||e.key==='S'){e.preventDefault();runSegment();return}if(e.key==='+'||e.key==='='){e.preventDefault();const ct=$('canvas-container');zoomAt(ct.clientWidth/2,ct.clientHeight/2,ZOOM_STEP);return}if(e.key==='-'||e.key==='_'){e.preventDefault();const ct=$('canvas-container');zoomAt(ct.clientWidth/2,ct.clientHeight/2,1/ZOOM_STEP);return}if(e.key==='0'){e.preventDefault();resetZoom();return}const sc={b:'bbox',p:'point',d:'brush',e:'eraser',k:'keypoint'};if(sc[e.key]){setTool(sc[e.key]);e.preventDefault()}const n=parseInt(e.key);if(n>=1&&n<=state.regions.length){state.activeRegion=state.regions[n-1].id;state.expandedRegion=state.regions[n-1].id;renderRegions();updateStatus();e.preventDefault()}});
window.addEventListener('resize',()=>{if(state.imgLoaded)drawImage()});

// ═══════════════════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded',()=>{
  initTools();initTemplateSelect();loadTemplate();
  SAM2.init();
  $('search-btn').addEventListener('click',searchGBIF);
  $('search-input').addEventListener('keydown',e=>{if(e.key==='Enter')searchGBIF()});
  $('url-btn').addEventListener('click',()=>{const u=$('url-input').value.trim();if(u)loadImage(u)});
  $('url-input').addEventListener('keydown',e=>{if(e.key==='Enter'){const u=$('url-input').value.trim();if(u)loadImage(u)}});
  const oc=$('overlay-canvas');oc.addEventListener('mousedown',onMouseDown);oc.addEventListener('mousemove',onMouseMove);oc.addEventListener('mouseup',onMouseUp);oc.addEventListener('contextmenu',e=>{e.preventDefault();onMouseDown(e)});
  $('brush-slider').addEventListener('input',e=>{state.brushSize=parseInt(e.target.value);$('brush-size-label').textContent=state.brushSize});
  $('tab-regions').addEventListener('click',()=>switchPanel('regions'));
  $('tab-export').addEventListener('click',()=>switchPanel('export'));
  $('segment-btn').addEventListener('click',runSegment);
  $('coco-import').addEventListener('change',e=>{const f=e.target.files[0];if(f){const r=new FileReader();r.onload=ev=>importCOCO(ev.target.result);r.readAsText(f)}});
  oc.style.cursor='crosshair';updateStatus();

  // Login popup
  loadAnnotator();
  $('login-btn').addEventListener('click',function(e){
    e.stopPropagation();
    const p=$('login-popup');
    p.classList.toggle('show');
    if(p.classList.contains('show')){
      $('login-name').value=annotator.name||'';
      $('login-orcid').value=annotator.orcid||'';
      $('login-institution').value=annotator.institution||'';
      $('login-name').focus();
    }
  });
  $('login-save').addEventListener('click',function(){
    annotator.name=$('login-name').value.trim();
    annotator.orcid=$('login-orcid').value.trim();
    annotator.institution=$('login-institution').value.trim();
    saveAnnotator();
    $('login-popup').classList.remove('show');
    if(annotator.name)showToast('Welcome, '+annotator.name+'!');
  });
  $('login-clear').addEventListener('click',function(){
    annotator={name:'',orcid:'',institution:''};
    saveAnnotator();
    $('login-popup').classList.remove('show');
    showToast('Annotator cleared');
  });
  document.addEventListener('click',function(e){
    if(!e.target.closest('.login-popup')&&!e.target.closest('#login-btn')){
      $('login-popup').classList.remove('show');
    }
  });

  // Local image upload
  $('local-image-input').addEventListener('change',function(e){
    const f=e.target.files[0];if(f)loadLocalImage(f);
  });

  // Drag-and-drop
  const cc=$('canvas-container');
  const dov=$('drop-overlay');
  let dragCounter=0;
  cc.addEventListener('dragenter',function(e){e.preventDefault();e.stopPropagation();dragCounter++;dov.classList.add('active');});
  cc.addEventListener('dragleave',function(e){e.preventDefault();e.stopPropagation();dragCounter--;if(dragCounter<=0){dragCounter=0;dov.classList.remove('active');}});
  cc.addEventListener('dragover',function(e){e.preventDefault();e.stopPropagation();});
  cc.addEventListener('drop',function(e){
    e.preventDefault();e.stopPropagation();
    dragCounter=0;dov.classList.remove('active');
    const files=e.dataTransfer.files;
    if(files.length>0&&files[0].type.startsWith('image/')){
      loadLocalImage(files[0]);
    } else {
      const url=e.dataTransfer.getData('text/uri-list')||e.dataTransfer.getData('text');
      if(url&&(url.startsWith('http')||url.startsWith('//'))){loadImage(url)}
    }
  });
  // Also support dropping on the whole page
  document.body.addEventListener('dragover',function(e){e.preventDefault()});
  document.body.addEventListener('drop',function(e){
    e.preventDefault();
    const files=e.dataTransfer.files;
    if(files.length>0&&files[0].type.startsWith('image/')){loadLocalImage(files[0])}
  });

  // ── Zoom: mouse wheel ──
  oc.addEventListener('wheel',function(e){
    e.preventDefault();
    const pos=getCanvasPos(e);
    const factor=e.deltaY<0?ZOOM_STEP:1/ZOOM_STEP;
    zoomAt(pos.cx,pos.cy,factor);
  },{passive:false});

  // ── Zoom: pinch-to-zoom (touch) ──
  let lastTouchDist=null;let lastTouchCenter=null;
  oc.addEventListener('touchstart',function(e){
    if(e.touches.length===2){
      e.preventDefault();
      const dx=e.touches[0].clientX-e.touches[1].clientX;
      const dy=e.touches[0].clientY-e.touches[1].clientY;
      lastTouchDist=Math.hypot(dx,dy);
      const rect=oc.getBoundingClientRect();
      lastTouchCenter={cx:(e.touches[0].clientX+e.touches[1].clientX)/2-rect.left,cy:(e.touches[0].clientY+e.touches[1].clientY)/2-rect.top};
    }
  },{passive:false});
  oc.addEventListener('touchmove',function(e){
    if(e.touches.length===2&&lastTouchDist!==null){
      e.preventDefault();
      const dx=e.touches[0].clientX-e.touches[1].clientX;
      const dy=e.touches[0].clientY-e.touches[1].clientY;
      const dist=Math.hypot(dx,dy);
      const factor=dist/lastTouchDist;
      lastTouchDist=dist;
      const rect=oc.getBoundingClientRect();
      const cx=(e.touches[0].clientX+e.touches[1].clientX)/2-rect.left;
      const cy=(e.touches[0].clientY+e.touches[1].clientY)/2-rect.top;
      zoomAt(cx,cy,factor);
    }
  },{passive:false});
  oc.addEventListener('touchend',function(e){
    if(e.touches.length<2){lastTouchDist=null;lastTouchCenter=null;}
  });

  // ── Pan: space key hold ──
  document.addEventListener('keydown',function(e){
    if(e.code==='Space'&&!['INPUT','TEXTAREA','SELECT'].includes(e.target.tagName)){
      if(!state.spaceDown){state.spaceDown=true;oc.style.cursor='grab'}
      e.preventDefault();
    }
  });
  document.addEventListener('keyup',function(e){
    if(e.code==='Space'){
      state.spaceDown=false;
      state.isPanning=false;state.panStart=null;
      oc.style.cursor={bbox:"crosshair",point:"crosshair",brush:"cell",eraser:"cell",keypoint:"crosshair"}[state.tool]||"crosshair";
    }
  });

  // ── Double-click to reset zoom ──
  oc.addEventListener('dblclick',function(e){
    if(state.zoom!==1||state.panX!==0||state.panY!==0){e.preventDefault();e.stopPropagation();resetZoom()}
  });

  // Prevent middle-click scroll
  oc.addEventListener('mousedown',function(e){if(e.button===1)e.preventDefault()});
});
</script>
</body>
</html>

