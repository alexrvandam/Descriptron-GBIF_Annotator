function reg(g,o){Object.entries(o).forEach(([k,v])=>{ALL_TEMPLATES[g+'__'+k]=v})}
reg("Formicidae",FORMICIDAE);reg("Coleoptera",COLEOPTERA);reg("Lepidoptera",LEPIDOPTERA);reg("Diptera",DIPTERA);
