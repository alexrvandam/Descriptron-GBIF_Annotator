<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Descriptron × GBIF — Web Morphology Annotator</title>
<script src="https://cdn.jsdelivr.net/npm/onnxruntime-web@1.20.0/dist/ort.all.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Roboto+Mono:wght@400;500&display=swap');
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Roboto',sans-serif;background:#f7f9f7;color:#333;height:100vh;width:100vw;overflow:hidden;display:flex;flex-direction:column}

  /* GBIF Colors */
  :root{
    --gbif-green:#509E2F;--gbif-green-dark:#3d7a23;--gbif-green-light:#e8f5e1;
    --gbif-green-pale:#f0f8ec;--bg:#ffffff;--bg-alt:#f5f6f5;--border:#e0e0e0;
    --text:#333333;--text-muted:#666666;--text-light:#999999;
    --danger:#d32f2f;--warning:#f9a825;--accent:#1976d2;
  }

  .header{display:flex;align-items:center;justify-content:space-between;padding:8px 16px;background:var(--gbif-green);color:white;flex-shrink:0}
  .header-left{display:flex;align-items:center;gap:10px}
  .header-title{font-size:15px;font-weight:700;letter-spacing:-0.02em}
  .header-title span{font-weight:400;opacity:0.8}
  .header-sub{font-size:10px;opacity:0.8}
  .header-right{text-align:right}
  .header-species{font-size:12px;font-weight:500;font-style:italic}
  .header-meta{font-size:10px;opacity:0.8}

  .main{display:flex;flex:1;overflow:hidden}

  .left-panel{width:200px;background:var(--bg);border-right:1px solid var(--border);padding:10px;overflow-y:auto;flex-shrink:0}
  .panel-label{color:var(--gbif-green-dark);font-size:10px;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:5px;font-weight:700}

  .tool-btn{display:flex;align-items:center;gap:8px;padding:7px 10px;background:transparent;border:1px solid transparent;border-radius:6px;color:var(--text-muted);cursor:pointer;font-size:12px;text-align:left;width:100%;font-family:inherit;transition:all 0.15s;margin-bottom:2px}
  .tool-btn:hover{background:var(--gbif-green-pale)}
  .tool-btn.active{background:var(--gbif-green-light);border-color:var(--gbif-green);color:var(--gbif-green-dark);font-weight:500}
  .tool-btn .icon{font-size:15px;width:20px;text-align:center}
  .tool-btn .shortcut{margin-left:auto;font-size:10px;color:var(--text-light);font-family:'Roboto Mono',monospace}

  .brush-slider{width:100%;accent-color:var(--gbif-green);margin-top:4px}

  .template-select,.view-select{width:100%;background:var(--bg);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:5px 6px;font-size:11px;font-family:inherit;margin-bottom:4px}
  .template-select:focus,.view-select:focus{border-color:var(--gbif-green);outline:none}

  .divider{border-top:1px solid var(--border);margin:10px 0;padding-top:10px}

  .sam-status-box{background:var(--bg-alt);border:1px solid var(--border);border-radius:6px;padding:8px;font-size:11px;color:var(--text-muted);margin-top:6px}
  .sam-dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:5px;vertical-align:middle}
  .sam-dot.off{background:var(--danger)}
  .sam-dot.encoding{background:var(--warning);animation:pulse 1s infinite}
  .sam-dot.ready{background:var(--gbif-green)}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}

  .segment-btn{width:100%;padding:8px;background:var(--gbif-green);color:white;border:none;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;margin-top:6px;transition:background 0.15s}
  .segment-btn:hover:not(:disabled){background:var(--gbif-green-dark)}
  .segment-btn:disabled{opacity:0.4;cursor:not-allowed}

  .tip-text{color:var(--text-light);font-size:10px;margin-top:8px;line-height:1.5;padding:0 2px}
  .tip-text strong{color:var(--text-muted)}

  .center{flex:1;display:flex;flex-direction:column;overflow:hidden}

  .search-bar{padding:8px 12px;background:var(--bg);border-bottom:1px solid var(--border);flex-shrink:0}
  .search-row{display:flex;gap:6px;margin-bottom:6px}
  .search-select{background:var(--bg);color:var(--text);border:1px solid var(--border);border-radius:6px;padding:6px 8px;font-size:12px;font-family:inherit}
  .search-input{flex:1;background:var(--bg);color:var(--text);border:1px solid var(--border);border-radius:6px;padding:6px 10px;font-size:12px;outline:none;font-family:inherit}
  .search-input:focus{border-color:var(--gbif-green)}
  .search-btn{background:var(--gbif-green);color:white;border:none;border-radius:6px;padding:6px 14px;font-size:12px;cursor:pointer;font-weight:600;font-family:inherit}
  .search-btn:disabled{opacity:0.5;cursor:not-allowed}
  .search-btn:hover:not(:disabled){background:var(--gbif-green-dark)}

  .results-list{max-height:160px;overflow-y:auto;background:var(--bg);border-radius:8px;border:1px solid var(--border);margin-bottom:6px}
  .result-item{display:flex;align-items:center;gap:10px;padding:8px 12px;cursor:pointer;border-bottom:1px solid var(--border);transition:background 0.15s}
  .result-item:hover{background:var(--gbif-green-pale)}
  .result-item:last-child{border-bottom:none}
  .result-thumb{width:44px;height:44px;object-fit:cover;border-radius:4px;background:var(--bg-alt)}
  .result-name{color:var(--gbif-green-dark);font-size:12px;font-weight:600;font-style:italic}
  .result-meta{color:var(--text-light);font-size:10px}

  .url-row{display:flex;gap:6px}
  .url-input{flex:1;background:var(--bg);color:var(--text);border:1px solid var(--border);border-radius:6px;padding:5px 10px;font-size:11px;outline:none;font-family:inherit}
  .url-btn{background:var(--bg-alt);color:var(--text-muted);border:1px solid var(--border);border-radius:6px;padding:5px 12px;font-size:11px;cursor:pointer;font-family:inherit}

  .canvas-area{flex:1;padding:6px;position:relative;background:var(--bg-alt)}
  .canvas-container{position:relative;width:100%;height:100%;background:#e8e8e8;border-radius:8px;overflow:hidden;border:1px solid var(--border)}
  .canvas-container canvas{position:absolute;top:0;left:0;width:100%;height:100%}
  .canvas-placeholder{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--text-light);font-size:14px;text-align:center}
  .canvas-placeholder .ph-icon{font-size:48px;margin-bottom:12px}

  .status-bar{display:flex;align-items:center;justify-content:space-between;padding:4px 12px;background:var(--bg);border-top:1px solid var(--border);font-size:10px;color:var(--text-light);flex-shrink:0;gap:12px;font-family:'Roboto Mono',monospace}
  .status-bar .hl{color:var(--gbif-green-dark);font-weight:500}

  .right-panel{width:270px;background:var(--bg);border-left:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
  .panel-tabs{display:flex;border-bottom:1px solid var(--border)}
  .panel-tab{flex:1;padding:8px 0;background:transparent;border:none;border-bottom:2px solid transparent;color:var(--text-light);font-size:11px;font-weight:600;cursor:pointer;font-family:inherit}
  .panel-tab.active{background:var(--gbif-green-pale);border-bottom-color:var(--gbif-green);color:var(--gbif-green-dark)}
  .panel-content{flex:1;overflow-y:auto;padding:10px}

  .region-item{display:flex;align-items:center;gap:6px;padding:6px 8px;border:1px solid transparent;border-radius:6px;cursor:pointer;transition:all 0.15s;margin-bottom:1px}
  .region-item:hover{background:var(--gbif-green-pale)}
  .region-item.active{background:var(--gbif-green-light);border-color:var(--gbif-green)}
  .region-color{width:10px;height:10px;border-radius:2px;flex-shrink:0}
  .region-label{color:var(--text-muted);font-size:11px;font-weight:500;flex:1;min-width:0}
  .region-item.active .region-label{color:var(--gbif-green-dark)}
  .region-ontology{color:var(--text-light);font-size:9px;font-family:'Roboto Mono',monospace}
  .region-badge{background:var(--gbif-green-light);color:var(--gbif-green-dark);font-size:9px;padding:1px 5px;border-radius:10px;font-weight:600}

  .attr-editor{margin-left:16px;margin-top:2px;margin-bottom:6px;padding:6px 8px;background:var(--bg-alt);border-radius:6px;border:1px solid var(--border)}
  .attr-label{color:var(--text-light);font-size:9px;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px}
  .attr-select{width:100%;background:var(--bg);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:3px 5px;font-size:11px;font-family:inherit;margin-bottom:4px}
  .attr-notes{width:100%;background:var(--bg);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:3px 5px;font-size:10px;resize:vertical;min-height:32px;margin-top:2px;font-family:inherit}
  .clear-btn{margin-top:4px;background:var(--danger);color:white;border:none;border-radius:4px;padding:3px 6px;font-size:10px;cursor:pointer;width:100%;font-family:inherit}

  .export-btn{width:100%;padding:8px 12px;border:none;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;margin-bottom:6px}
  .export-btn.primary{background:var(--gbif-green);color:white}
  .export-btn.primary:hover{background:var(--gbif-green-dark)}
  .export-btn.secondary{background:var(--bg-alt);color:var(--text-muted);border:1px solid var(--border)}
  .export-btn.secondary:hover{background:var(--border)}

  .auto-badge{display:inline-block;background:var(--gbif-green);color:white;font-size:9px;padding:1px 5px;border-radius:4px;font-weight:600;margin-left:4px}

  
  .login-btn{background:rgba(255,255,255,0.2);color:white;border:1px solid rgba(255,255,255,0.3);border-radius:6px;padding:5px 10px;font-size:11px;cursor:pointer;font-family:inherit;transition:all 0.15s;display:flex;align-items:center;gap:5px;white-space:nowrap}
  .login-btn:hover{background:rgba(255,255,255,0.3)}
  .login-btn.logged-in{background:rgba(255,255,255,0.25);border-color:rgba(255,255,255,0.6)}
  .login-popup{position:absolute;top:36px;right:0;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:12px;box-shadow:0 4px 20px rgba(0,0,0,0.15);z-index:100;width:220px;display:none}
  .login-popup.show{display:block}
  .login-popup label{color:var(--text-muted);font-size:10px;text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:3px;margin-top:6px}
  .login-popup label:first-child{margin-top:0}
  .login-popup input{width:100%;background:var(--bg);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-size:12px;font-family:inherit}
  .login-popup input:focus{border-color:var(--gbif-green);outline:none}
  .login-popup .login-save{width:100%;padding:6px;background:var(--gbif-green);color:white;border:none;border-radius:4px;font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;margin-top:8px}
  .login-popup .login-save:hover{background:var(--gbif-green-dark)}

  .drop-overlay{position:absolute;inset:0;background:rgba(80,158,47,0.15);border:3px dashed var(--gbif-green);border-radius:8px;display:none;align-items:center;justify-content:center;z-index:50;pointer-events:none}
  .drop-overlay.active{display:flex}
  .drop-overlay-text{background:var(--gbif-green);color:white;padding:12px 24px;border-radius:8px;font-size:14px;font-weight:600}

  .toast{position:fixed;top:16px;left:50%;transform:translateX(-50%);background:#333;color:white;padding:8px 20px;border-radius:8px;font-size:12px;z-index:9999;opacity:0;transition:opacity 0.3s;pointer-events:none}
  .toast.show{opacity:1}

  ::-webkit-scrollbar{width:5px}
  ::-webkit-scrollbar-track{background:transparent}
  ::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
</style>
</head>
<body>

<div class="header">
  <div class="header-left">
    <span style="font-size:20px">🔬</span>
    <div>
      <div class="header-title">DESCRIPTRON <span>× GBIF</span></div>
      <div class="header-sub">Web Morphology Annotator · MfN Berlin</div>
    </div>
  </div>
  <div class="header-right" style="display:flex;align-items:center;gap:12px">
    <div id="specimen-info" style="display:none;text-align:right">
      <div class="header-species" id="specimen-name"></div>
      <div class="header-meta" id="specimen-meta"></div>
    </div>
    <div style="position:relative">
      <button class="login-btn" id="login-btn" title="Optional: set your name for annotations">
        <span id="login-icon">👤</span>
        <span id="login-label">Login</span>
      </button>
      <div class="login-popup" id="login-popup">
        <label>Annotator Name</label>
        <input type="text" id="login-name" placeholder="e.g. J. Smith">
        <label>ORCID <span style="font-size:8px;opacity:0.6">(optional)</span></label>
        <input type="text" id="login-orcid" placeholder="0000-0000-0000-0000">
        <label>Institution <span style="font-size:8px;opacity:0.6">(optional)</span></label>
        <input type="text" id="login-institution" placeholder="e.g. MfN Berlin">
        <button class="login-save" id="login-save">Save</button>
        <button class="login-clear" id="login-clear" style="width:100%;padding:4px;background:transparent;color:var(--text-light);border:1px solid var(--border);border-radius:4px;font-size:10px;cursor:pointer;font-family:inherit;margin-top:4px">Clear</button>
      </div>
    </div>
  </div>
</div>

<div class="main">
  <div class="left-panel">
    <div class="panel-label">Tools</div>
    <div id="tools-container"></div>
    <div style="margin-top:4px;padding:0 4px;display:none" id="brush-controls">
      <div style="color:var(--text-light);font-size:10px;margin-bottom:3px">Size: <span id="brush-size-label">10</span>px</div>
      <input type="range" min="2" max="40" value="10" class="brush-slider" id="brush-slider">
    </div>

    <div class="divider">
      <div class="panel-label">Template</div>
      <div id="auto-detect-msg" style="display:none;color:var(--gbif-green);font-size:10px;margin-bottom:4px"></div>
      <select class="template-select" id="template-select"></select>
      <select class="view-select" id="view-select"></select>
      <div style="color:var(--text-light);font-size:10px;margin-top:2px" id="template-info"></div>
    </div>

    <div class="divider">
      <div class="panel-label">SAM2.1 Segmentation</div>
      <div class="sam-status-box">
        <span class="sam-dot off" id="sam-dot"></span>
        <span id="sam-status-text">Connecting...</span>
      </div>
      <button class="segment-btn" id="segment-btn" disabled>⚡ Segment Region</button>
      <div style="color:var(--text-light);font-size:9px;margin-top:4px;line-height:1.4" id="sam-help">
        Draw points or bbox, then click Segment.
      </div>
    </div>

    <div class="divider">
      <div class="panel-label">Import</div>
      <label class="export-btn secondary" style="text-align:center;cursor:pointer;display:block;margin-bottom:0">
        📂 Load COCO JSON
        <input type="file" accept=".json" id="coco-import" style="display:none">
      </label>
    </div>

    <div class="tip-text">
      <strong>Shortcuts:</strong><br>
      B=Box P=Point K=Kpt D=Brush E=Eraser<br>
      Ctrl+Z=Undo Ctrl+Y=Redo<br>
      1-9=Region · S=Segment<br>Scroll=Zoom · Space+Drag=Pan · 0=Reset
    </div>
  </div>

  <div class="center">
    <div class="search-bar">
      <div class="search-row">
        <select class="search-select" id="search-mode">
          <option value="species">Species Name</option>
          <option value="occurrence">Occurrence ID</option>
        </select>
        <input class="search-input" id="search-input" placeholder="e.g. Tetramorium caespitum">
        <button class="search-btn" id="search-btn">Search GBIF</button>
      </div>
      <div id="results-container"></div>
      <div class="url-row">
        <input class="url-input" id="url-input" placeholder="Or paste image URL directly...">
        <button class="url-btn" id="url-btn">Load</button>
        <label class="url-btn" style="cursor:pointer;display:flex;align-items:center;gap:4px" title="Upload a local image">
          📷 Upload
          <input type="file" accept="image/*" id="local-image-input" style="display:none">
        </label>
      </div>
    </div>
    <div class="canvas-area">
      <div class="canvas-container" id="canvas-container">
        <div class="drop-overlay" id="drop-overlay"><div class="drop-overlay-text">📷 Drop image here</div></div>
        <canvas id="img-canvas"></canvas>
        <canvas id="overlay-canvas"></canvas>
        <div class="canvas-placeholder" id="canvas-placeholder">
          <div><div class="ph-icon">🔬</div><div>Search GBIF, paste URL, drag & drop, or upload an image</div></div>
        </div>
      </div>
    </div>
    <div class="status-bar">
      <span>Tool: <span class="hl" id="status-tool">bbox</span></span>
      <span>Region: <span id="status-region" style="color:var(--text-light)">none</span></span>
      <span id="status-template"></span>
      <span>Zoom: <span class="hl" id="status-zoom">100%</span></span><span id="status-progress">0/0</span>
      <span id="status-uri" style="color:var(--text-light);font-size:9px"></span>
    </div>
  </div>

  <div class="right-panel">
    <div class="panel-tabs">
      <button class="panel-tab active" data-tab="regions" id="tab-regions">Regions</button>
      <button class="panel-tab" data-tab="export" id="tab-export">Export</button>
    </div>
    <div class="panel-content" id="panel-content"></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ═══════════════════════════════════════════════════════════════════════
// COLORS & ATTRIBUTES
// ═══════════════════════════════════════════════════════════════════════
const COLORS=["#e53935","#f9a825","#43a047","#1e88e5","#8e24aa","#d81b60","#00acc1","#fb8c00","#7cb342","#26a69a","#5c6bc0","#ab47bc","#039be5","#c0ca33","#66bb6a","#7e57c2","#c62828","#00838f","#558b2f","#6a1b9a"];
function c(i){return COLORS[i%COLORS.length]}
const ATTR={
  texture:["smooth","rugose","striate","punctate","areolate","reticulate","granulate","coriaceous","alutaceous","shagreened","imbricate","tuberculate","verrucose","foveate"],
  sculpture:["carinae","costulae","costae","foveae","sulci","rugae","striae","none"],
  setae:["absent","sparse","dense","appressed","erect","suberect","decumbent","plumose","scale-like","spatulate","simple","branched"],
  color:["black","dark brown","brown","light brown","yellow","orange","red","ferruginous","testaceous","piceous","castaneous","flavous","ochraceous","white","cream","metallic green","metallic blue","metallic copper","bicolored","mottled","striped","banded"],
  color_pattern:["uniform","bicolored","tricolored","mottled","spotted","striped","banded","maculate","vittate","fasciate"],
  shape:["convex","flat","concave","angular","rounded","emarginate","truncate","acuminate","acute","obtuse"],
  margin:["entire","crenulate","serrate","dentate","sinuate","carinate","lamellate"],
  surface_covering:["bare","pruinose","tomentose","sericeous","pubescent","pilose","villous","lanate","setose"],
};

// ═══════════════════════════════════════════════════════════════════════
// MORPHOLOGY TEMPLATES (abbreviated — same as v2)
// ═══════════════════════════════════════════════════════════════════════
const FORMICIDAE={
  head_dorsal:{group:"Formicidae",view:"Head (dorsal)",regions:[
    {id:"mandible",label:"Mandible",color:c(0),ontology:"HAO:0000506"},{id:"clypeus",label:"Clypeus",color:c(1),ontology:"HAO:0000212"},
    {id:"frons",label:"Frons",color:c(2),ontology:"HAO:0000352"},{id:"eye",label:"Compound Eye",color:c(3),ontology:"HAO:0000217"},
    {id:"antenna_scape",label:"Antennal Scape",color:c(4),ontology:"HAO:0000908"},{id:"antenna_funiculus",label:"Funiculus",color:c(5),ontology:"HAO:0000357"},
    {id:"gena",label:"Gena",color:c(6),ontology:"HAO:0000371"},{id:"vertex",label:"Vertex",color:c(7),ontology:"HAO:0001077"},
    {id:"occiput",label:"Occiput",color:c(8),ontology:"HAO:0000658"},{id:"frontal_carina",label:"Frontal Carina",color:c(9),ontology:"HAO:0000355"},
    {id:"antennal_scrobe",label:"Antennal Scrobe",color:c(10),ontology:"HAO:0000908"},
  ],attributes:{texture:ATTR.texture,sculpture:ATTR.sculpture,setae:ATTR.setae,color:ATTR.color,color_pattern:ATTR.color_pattern}},
  head_frontal:{group:"Formicidae",view:"Head (full-face)",regions:[
    {id:"mandible",label:"Mandible",color:c(0),ontology:"HAO:0000506"},{id:"clypeus",label:"Clypeus",color:c(1),ontology:"HAO:0000212"},
    {id:"frons",label:"Frons",color:c(2),ontology:"HAO:0000352"},{id:"eye",label:"Compound Eye",color:c(3),ontology:"HAO:0000217"},
    {id:"frontal_lobe",label:"Frontal Lobe",color:c(4),ontology:"HAO:0000354"},{id:"antennal_insertion",label:"Antennal Insertion",color:c(5),ontology:"HAO:0000908"},
    {id:"gena",label:"Gena",color:c(6),ontology:"HAO:0000371"},{id:"posterior_margin",label:"Posterior Head Margin",color:c(7),ontology:"HAO:0000658"},
  ],attributes:{texture:ATTR.texture,sculpture:ATTR.sculpture,setae:ATTR.setae,color:ATTR.color,margin:ATTR.margin}},
  mesosoma_lateral:{group:"Formicidae",view:"Mesosoma (lateral)",regions:[
    {id:"pronotum",label:"Pronotum",color:c(0),ontology:"HAO:0000853"},{id:"mesonotum",label:"Mesonotum",color:c(1),ontology:"HAO:0000575"},
    {id:"mesopleuron",label:"Mesopleuron",color:c(2),ontology:"HAO:0000566"},{id:"propodeum",label:"Propodeum",color:c(3),ontology:"HAO:0000862"},
    {id:"propodeal_spine",label:"Propodeal Spine",color:c(4),ontology:"HAO:0000860"},{id:"metapleuron",label:"Metapleuron",color:c(5),ontology:"HAO:0000621"},
